  <folder name="Motivation" id="id-907fd67163d84897b456bfb885ce6640" type="motivation">
    <element xsi:type="archimate:Stakeholder" name="Produtor Rural" id="id-02eec42620ca4bb0abe77446c9a27dc3"/>
    <element xsi:type="archimate:Stakeholder" name="Proprietário da Fazenda" id="id-27b71e81a14b4f06b4309ba76dd861dd"/>
    <element xsi:type="archimate:Stakeholder" name="Equipe Terra Nova" id="id-c42c6b73bc9e41d1bb544a352e9badff"/>
    <element xsi:type="archimate:Driver" name="Dificuldade em mapear, organizar e gerenciar a estrutura física das áreas de plantio" id="id-6ed3d9c26dbd461a93bf9ed25bbeef75"/>
    <element xsi:type="archimate:Driver" name="Dificuldade em acompanhar as condições climáticas e falta de visibilidade dos indicadores de saúde da lavoura" id="id-6beacf1e4ed54f8ebdd90cbf29d127e2"/>
    <element xsi:type="archimate:Driver" name="Necessidade de acompanhar o histórico de modificações na conta" id="id-5406792e79ca4abfa3502f04573070fe"/>
    <element xsi:type="archimate:Driver" name="Necessidade de mapear anomalias climáticas e falta de histórico consolidado de riscos na região" id="id-0bb1478721fe43109d80aaf37562a5d7"/>
    <element xsi:type="archimate:Goal" name="Estruturar e georreferenciar de forma clara as propriedades e talhões agrícolas" id="id-7251912146c94d82b695c243840b17ff"/>
    <element xsi:type="archimate:Goal" name="Melhorar a tomada de decisão operacional" id="id-76681323abb34f85a3d675adf83f9a95"/>
    <element xsi:type="archimate:Goal" name="Garantir controle e transparência das atividades realizadas" id="id-b13cab6b13ab4b18b7619779db70a9c7"/>
    <element xsi:type="archimate:Goal" name="Monitorar e mitigar riscos operacionais e biológicos no campo" id="id-1e97ecf7250b4827998425f04d2545c2"/>
    <element xsi:type="archimate:Requirement" name="Gerenciamento Estratégico de Propriedades e Talhões" id="id-78aaecb32611458a984a5c3b0cf76247"/>
    <element xsi:type="archimate:Requirement" name="Dashboard de Monitorização Central" id="id-5fb102d2c83640ae9e160e5e8922db6b"/>
    <element xsi:type="archimate:Requirement" name="Central de Alertas Agrícolas" id="id-9272895db8564d86b20031656d0427c2"/>
    <element xsi:type="archimate:Requirement" name="Histórico de Colheitas" id="id-2b944131aad54cb295d6e5094b6de51a"/>
    <element xsi:type="archimate:Requirement" name="Agendamento de Tarefas" id="id-dded35bf9b344997b435a387017565a7"/>
    <element xsi:type="archimate:Requirement" name="Logs de Atividades" id="id-b4a35460c1734531a231292f3a6d9c0f"/>
    <element xsi:type="archimate:Requirement" name="Central de Suporte e Manual (FAQ)" id="id-bdefd8962c204daab35053781e10d60a"/>
    <element xsi:type="archimate:Constraint" name="Cada talhão cadastrado deve possuir coordenadas GPS (utilizando SDO_GEOMETRY)" id="id-0130f7cbd9dd462da389794a128dc5d2"/>
    <element xsi:type="archimate:Constraint" name="Os dados apresentados serão extraídos em tempo real via APIs de satélite (NASA Power e Embrapa SATVeg)" id="id-dcd006c2d8dd4005ade1fec2d27ec11e"/>
    <element xsi:type="archimate:Constraint" name="O sistema deve registrar data e hora de cada ação do usuário" id="id-c6d30924f2054b1bbcc23727764366fa"/>
    <element xsi:type="archimate:Constraint" name="Toda colheita deve registrar quantidade produzida em quilogramas (kg)" id="id-68d497650ec04787908fc88fe5150297"/>
    <element xsi:type="archimate:Principle" name="Principle" id="id-64b984df91174caf96e5a5e1b783b512"/>
    <element xsi:type="archimate:Constraint" name="Os alertas gerados devem possuir classificação de severidade (Alto, Médio ou Baixo risco)" id="id-0e93676d928e45c885d0f9d68eab129b"/>
    <element xsi:type="archimate:Goal" name="Melhorar a capacitação do usuário" id="id-f61fafe446a74f45b6a7ce3e5b197add"/>
  </folder>
